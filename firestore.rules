rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: id, email, name, role, plan, createdAt, lastLogin
    //
    // Collection: tools
    // Fields: id, userId, name, url, description, category, targetAudience, primaryGoal, status, createdAt, updatedAt
    //
    // Collection: content
    // Fields: id, toolId, type, platform, status, assets, metadata, createdAt, publishedAt
    //
    // Collection: posts
    // Fields: id, contentId, platform, scheduledTime, publishedTime, status, platformPostId, metrics, botatoWorkflowId

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "mrdelivery.ro@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['id', 'email', 'role', 'plan']) &&
             data.role in ['admin', 'editor', 'viewer'] &&
             data.plan in ['free', 'pro', 'enterprise'];
    }

    function isValidProject(data) {
      return data.keys().hasAll(['id', 'userId', 'currentStep', 'status']) &&
             data.userId == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin());
    }

    match /projects/{projectId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidProject(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /approvals/{approvalId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
    }

    match /analytics/{analyticsId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }
  }
}
